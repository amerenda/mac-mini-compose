# Copy to compose.local.env (see repo .gitignore) on the Mac Mini for optional overrides.
#
# AGENT_ADDRESS — URL the llm-manager backend uses to reach this agent (registration + API).
# Required when the backend runs on k3s or another network: Docker/OrbStack often yields a
# bridge/container IP that the cluster cannot route to; use your Tailscale IP, LAN IP, or DNS.
# AGENT_ADDRESS=https://100.x.y.z:8090
#
# AGENT_IMAGE_TAG=sha-abc1234
