# Merged into llm/.env on every Komodo deploy (see llm/pre-deploy.sh).
# Edit via PR — nothing here is applied by hand on the Mac Mini.
#
# LAN IP of the Mac Mini (same host as Komodo, Postgres, etc. — see k3s ingresses / infra docs).
# k3s pods reach this via the home LAN / Tailscale-advertised 10.100.20.0/24 route.
AGENT_ADDRESS=https://10.100.20.18:8090

# Optional: pin agent image when you cannot wait for target-version resolution:
# AGENT_IMAGE_TAG=sha-abc1234
