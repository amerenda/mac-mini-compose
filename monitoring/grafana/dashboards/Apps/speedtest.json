  "uid": "speedtest",
  "schemaVersion": 38,
  "version": 1,
  "tags": [
    "network",
    "speedtest"
  ],
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "1h",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Latest Download",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 700
              },
              {
                "color": "green",
                "value": 900
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "last_over_time(speedtest_download_bits_per_second[20m]) / 1e6",
          "refId": "A",
          "instant": true
        }
      ]
    },
