        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "60 * ((sum(rate(llm_scheduler_job_inference_seconds_count[5m]))) or (sum(rate(llm_scheduler_v2_jobs_completed_total{status=\"completed\"}[5m]))))",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "60 * ((sum(rate(llm_scheduler_job_errors_total[5m]))) or (sum(rate(llm_scheduler_v2_jobs_completed_total{status=~\"retried|failed|error\"}[5m]))))",
          "legendFormat": "errors",
          "refId": "B"
        },
        {
          "expr": "60 * sum by (runner) (rate(llm_scheduler_v2_model_swap_total{runner=~\"$runner\"}[5m]))",
          "legendFormat": "{{runner}} model swaps/min",
          "refId": "C"
        }
      ]
    },
