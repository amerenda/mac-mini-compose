{
  "uid": "app-ecdysis",
  "title": "Ecdysis",
  "tags": [
    "ecdysis",
    "moltbook"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "title": "Agents Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Running Agents",
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "max(moltbook_backend_agents_running)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Heartbeats (1h)",
      "id": 3,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(moltbook_heartbeat_total{status=\"success\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Posts (1h)",
      "id": 4,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(moltbook_posts_total[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "LLM Errors (1h)",
      "id": 5,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(moltbook_llm_calls_total{status=~\"error|timeout\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Process Uptime",
      "id": 6,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "max(time() - process_start_time_seconds{job=\"ecdysis-backend\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pod Restarts (24h)",
      "id": 7,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"ecdysis\", container=\"ecdysis-backend\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Heartbeats & Posts",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 10,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Heartbeats by Slot",
      "id": 11,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true,
            "drawStyle": "bars"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "increase(moltbook_heartbeat_total{status=\"success\"}[1h])",
          "legendFormat": "slot {{slot}} ok",
          "refId": "A"
        },
        {
          "expr": "increase(moltbook_heartbeat_total{status=\"error\"}[1h])",
          "legendFormat": "slot {{slot}} error",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Heartbeat Duration by Slot",
      "id": 12,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(moltbook_heartbeat_duration_seconds_sum[10m]) / rate(moltbook_heartbeat_duration_seconds_count[10m])",
          "legendFormat": "slot {{slot}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Posts Created",
      "id": 13,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true,
            "drawStyle": "bars"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "increase(moltbook_posts_total[1h])",
          "legendFormat": "slot {{slot}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "LLM Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 20,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "LLM Call Latency (p50 / p95)",
      "id": 21,
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(moltbook_llm_call_seconds_bucket[5m])) by (le, slot))",
          "legendFormat": "p50 slot {{slot}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(moltbook_llm_call_seconds_bucket[5m])) by (le, slot))",
          "legendFormat": "p95 slot {{slot}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Calls (success / timeout / error)",
      "id": 22,
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(moltbook_llm_calls_total{status=\"success\"}[5m])) by (slot) * 60",
          "legendFormat": "slot {{slot}} success/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(moltbook_llm_calls_total{status=\"timeout\"}[5m])) by (slot) * 60",
          "legendFormat": "slot {{slot}} timeout/min",
          "refId": "B"
        },
        {
          "expr": "sum(rate(moltbook_llm_calls_total{status=\"error\"}[5m])) by (slot) * 60",
          "legendFormat": "slot {{slot}} error/min",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "API & Errors",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 30,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "id": 31,
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(moltbook_backend_api_requests_total[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Moltbook API Errors by Status",
      "id": 32,
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(moltbook_api_errors_total[5m])) by (slot, status_code) * 60",
          "legendFormat": "slot {{slot}} HTTP {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Process",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 40,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Process RSS Memory",
      "id": 41,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"ecdysis-backend\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU",
      "id": 42,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 30
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"ecdysis-backend\"}[5m])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Open File Descriptors",
      "id": 43,
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 30
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "process_open_fds{job=\"ecdysis-backend\"}",
          "legendFormat": "Open FDs",
          "refId": "A"
        }
      ]
    }
  ]
}
