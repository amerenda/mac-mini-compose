## Komodo Compose Environment
## Secrets are injected via _FILE pattern from ./secrets/ directory.
## Non-secret config lives here directly.

## Image version
COMPOSE_KOMODO_IMAGE_TAG=latest

## DB credentials — password is written by Ansible at deploy time.
## Must be plaintext here because Postgres/FerretDB containers
## don't support the _FILE pattern (only Komodo Core/Periphery do).
KOMODO_DB_USERNAME=komodo
KOMODO_DB_PASSWORD=ANSIBLE_WILL_REPLACE_THIS

## Core ↔ Periphery auth — injected from Bitwarden via Ansible
KOMODO_PASSKEY_FILE=/run/secrets/passkey

## Timezone
TZ=America/New_York

## Core config
KOMODO_HOST=https://komodo.amer.dev
KOMODO_TITLE=Komodo
KOMODO_FIRST_SERVER=https://periphery:8120
KOMODO_FIRST_SERVER_NAME=mac-mini-m4
KOMODO_DISABLE_CONFIRM_DIALOG=false

## Monitoring
KOMODO_MONITORING_INTERVAL=15-sec
KOMODO_RESOURCE_POLL_INTERVAL=1-hr

## Auth secrets — injected from Bitwarden via Ansible
KOMODO_WEBHOOK_SECRET_FILE=/run/secrets/webhook_secret
KOMODO_JWT_SECRET_FILE=/run/secrets/jwt_secret

## Local auth
KOMODO_LOCAL_AUTH=true
KOMODO_INIT_ADMIN_USERNAME=admin
## Admin password — Ansible injects at deploy time (only used on first launch)
KOMODO_INIT_ADMIN_PASSWORD=ANSIBLE_WILL_REPLACE_THIS
KOMODO_DISABLE_USER_REGISTRATION=true
KOMODO_ENABLE_NEW_USERS=false
KOMODO_TRANSPARENT_MODE=false

## GitHub OAuth (enable after initial setup if desired)
KOMODO_GITHUB_OAUTH_ENABLED=false
# KOMODO_GITHUB_OAUTH_ID_FILE=/run/secrets/github_oauth_id
# KOMODO_GITHUB_OAUTH_SECRET_FILE=/run/secrets/github_oauth_secret

## Logging
KOMODO_LOGGING_PRETTY=false
KOMODO_PRETTY_STARTUP_CONFIG=false

## Periphery config
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
## Periphery passkey — Ansible injects at deploy time
PERIPHERY_PASSKEYS=ANSIBLE_WILL_REPLACE_THIS
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_SSL_ENABLED=true
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
