# Merged into archlinux/llm/.env on every Komodo deploy (see llm/pre-deploy.sh).
#
# LAN IP of archlinux (llm-manager backend reaches agents here).
AGENT_ADDRESS=https://10.100.20.25:8090

# When true, pre-deploy skips configure-native-ollama-bind (no systemd touch, no Ollama start).
# Remove after maintenance (e.g. rsync to ~/.ollama).
KOMODO_SKIP_NATIVE_OLLAMA_BIND=true

# Optional: pin agent image when you cannot wait for target-version resolution:
# AGENT_IMAGE_TAG=sha-abc1234
