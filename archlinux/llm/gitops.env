# Merged into archlinux/llm/.env on every Komodo deploy (see llm/pre-deploy.sh).
#
# LAN IP of archlinux (llm-manager backend reaches agents here).
AGENT_ADDRESS=https://10.100.20.25:8090

# Ollama data + model blobs on this host (Komodo pre-deploy runs as root — set explicit paths).
OLLAMA_DATA_HOST_PATH=/mnt/storage
OLLAMA_MODELS_HOST_PATH=/mnt/storage/models

# Optional: pin agent image when you cannot wait for target-version resolution:
# AGENT_IMAGE_TAG=sha-abc1234
#
# Optional: override GPU stack labels in llm-manager (pre-deploy auto-fills from the host if unset):
# ROCM_VERSION=7.2.2
# AGENT_AMD_DRIVER_VERSION=linux-7.0.2-arch1-1
