# archlinux/media-server — environment template
#
# Komodo's pre_deploy renders the real .env from this template plus secrets
# fetched from Bitwarden. Do not commit real values; .env is gitignored.

# ── Config volumes (/opt/media is pre-created by setup-archlinux-komodo.yml)
CONFIG_BASE=/opt/media
PROFILARR_CONFIG=${CONFIG_BASE}/profilarr/config
WHISPARR_CONFIG=${CONFIG_BASE}/whisparr/config
RADARR_CONFIG=${CONFIG_BASE}/radarr/config
BAZARR_CONFIG=${CONFIG_BASE}/bazarr/config
SONARR_CONFIG=${CONFIG_BASE}/sonarr/config
SONARR_SCRIPTS=${CONFIG_BASE}/sonarr/scripts
PROWLARR_CONFIG=${CONFIG_BASE}/prowlarr/config
SABNZBD_CONFIG=${CONFIG_BASE}/sabnzbd/config
JELLYFIN_CONFIG=${CONFIG_BASE}/jellyfin/config

# ── Library volumes (/mnt/storage is mounted out of band)
DATA_BASE=/mnt/storage
MOVIES_FOLDER=${DATA_BASE}/movies
TV_FOLDER=${DATA_BASE}/tv
BOOKS_FOLDER=${DATA_BASE}/books
WHISPARR_FOLDER=${DATA_BASE}/misc/porn
USENET_DOWNLOADS=${DATA_BASE}/downloads/complete
USENET_DOWNLOADS_INCOMPLETE=${DATA_BASE}/downloads/incomplete
TRANSCODE_FOLDER=${DATA_BASE}/cache/transcode

# ── certbot / nginx
CERT_FOLDER=/etc/letsencrypt/
NGINX_FOLDER=./nginx/config

# ── Public URL (also drives certbot's -d argument and the DO dyndns subdomain)
JELLYFIN_URL=media.amer.dev

# ── DigitalOcean dyndns (dns container).
# Real value comes from BWS at deploy time — do not put a token here.
DO_API_TOKEN=
