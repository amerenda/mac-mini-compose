# ═══════════════════════════════════════════════════════════
# SCENE TEMPLATE — Color lights (Hue White and Color Ambiance)
# ═══════════════════════════════════════════════════════════
# Supports: brightness (0-255), color_temp (153-500 mired), color xy/hs
#
# Color temp reference (mired):
#   153 = 6500K daylight     250 = 4000K cool
#   370 = 2700K soft white   454 = 2200K warm    500 = 2000K candlelight
#
# Copy, rename to <room>.yaml, replace ROOM and light entities.
# Rooms with color lights: living_room, bedroom, bathroom

- id: ROOM_morning
  name: ROOM_morning
  entities:
    light.ROOM_0:
      state: "on"
      brightness: 200
      color_temp: 300

- id: ROOM_day
  name: ROOM_day
  entities:
    light.ROOM_0:
      state: "on"
      brightness: 254
      color_temp: 250

- id: ROOM_evening
  name: ROOM_evening
  entities:
    light.ROOM_0:
      state: "on"
      brightness: 180
      color_temp: 400

- id: ROOM_night
  name: ROOM_night
  entities:
    light.ROOM_0:
      state: "on"
      brightness: 80
      color_temp: 500


