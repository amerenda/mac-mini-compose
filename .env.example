# Mac Mini Compose — Environment Variables
# Each stack has its own .env in its directory (core/.env, monitoring/.env).
# These are generated at deploy time by Komodo pre_deploy scripts via BWS.
# NEVER commit .env files to git.
#
# BWS Projects (secrets named as env var names):
#   mac-mini-core       → core/.env
#   mac-mini-monitoring → monitoring/.env
#   mac-mini-automation → (no secrets currently)
#
# === core/.env ===
# TECHNITIUM_ADMIN_PASSWORD=    # DNS admin UI (BWS: technitium-admin-password)
# MINI_POSTGRES_PASSWORD=       # Postgres superuser (BWS: mini-postgres-password)
# MINI_POSTGRES_TODO_PASSWORD=  # todo db user (BWS: mini-postgres-todo-password)
# AGENT_KB_PASSWORD=            # agent_kb db user (BWS: agent-kb-dean-password)
# MONGO_PASSWORD=               # MongoDB root (BWS: unifi-mongo-credentials)
# BACKUP_ACCESS_KEY=            # GCS HMAC key (BWS: k3s-dean-backups-access-key)
# BACKUP_SECRET_KEY=            # GCS HMAC secret (BWS: k3s-dean-backups-secret-key)
# BACKUP_ENDPOINT=              # GCS S3 endpoint (BWS: k3s-dean-backups-endpoint)
#
# === monitoring/.env ===
# TECHNITIUM_API_TOKEN=         # Technitium read-only API token for exporter
# MINI_POSTGRES_PASSWORD=       # Postgres password (for postgres-exporter DSN)
# MONGO_PASSWORD=               # MongoDB password (for mongodb-exporter URI)
#
# === monitoring/ha-token ===
# (plain text file, not .env — HA long-lived access token for Prometheus)
#
# === File-based secrets (not env vars) ===
# bind9/keys/key.conf           # BIND9 TSIG key (BWS: 9904dc3d-...)
