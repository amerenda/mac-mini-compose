# Mac Mini Compose — Environment Variables
# Copy to .env and fill in values from Bitwarden
# NEVER commit .env to git

# Pihole admin UI password (from Bitwarden: pihole-admin)
PIHOLE_WEBPASSWORD=

# Agent KB PostgreSQL password (from Bitwarden: agent-kb-dean-password)
AGENT_KB_PASSWORD=

# SMLIGHT Zigbee coordinator static IP (hardcoded in zigbee2mqtt/configuration.yaml)
# SMLIGHT_IP=10.100.20.179

# BIND9 TSIG key is stored in bind9/keys/key.conf (not here)
# Format:
#   key "externaldns-key." {
#     algorithm hmac-sha256;
#     secret "<base64-secret-from-bitwarden>";
#   };
