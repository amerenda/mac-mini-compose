{
  "title": "Vikunja",
  "uid": "vikunja-app",
  "tags": [
    "app",
    "vikunja"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{exported_service=\"vikunja-vikunja-3456@kubernetes\"}[2m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Response Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traefik_service_request_duration_seconds_bucket{exported_service=\"vikunja-vikunja-3456@kubernetes\"}[2m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(traefik_service_request_duration_seconds_bucket{exported_service=\"vikunja-vikunja-3456@kubernetes\"}[2m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traefik_service_request_duration_seconds_bucket{exported_service=\"vikunja-vikunja-3456@kubernetes\"}[2m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{exported_service=\"vikunja-vikunja-3456@kubernetes\", code=~\"[45]..\"}[2m]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"vikunja\", container!=\"\"}[2m])) by (container)",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"vikunja\", container!=\"\"}) by (container)",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request Volume by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{exported_service=\"vikunja-vikunja-3456@kubernetes\"}[2m])) by (code)",
          "legendFormat": "HTTP {{code}}"
        }
      ]
    }
  ],
  "schemaVersion": 38
}