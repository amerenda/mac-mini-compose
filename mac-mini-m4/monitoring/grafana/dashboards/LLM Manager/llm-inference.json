{
  "title": "LLM Inference",
  "uid": "llm-inference",
  "tags": [
    "llm-manager"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "VRAM Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_memory_used{node=\"murderbot\"}",
          "legendFormat": "{{gpu}} used"
        },
        {
          "expr": "nvidia_gpu_memory_total{node=\"murderbot\"}",
          "legendFormat": "{{gpu}} total",
          "hide": false
        }
      ],
      "fieldConfig.defaults.thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "#EAB839",
            "value": 15000000000.0
          },
          {
            "color": "red",
            "value": 21000000000.0
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "VRAM Utilization %",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 8,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholds": true
      },
      "fieldConfig.defaults": {
        "unit": "percent",
        "min": 0,
        "max": 100,
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "#EAB839",
              "value": 60
            },
            {
              "color": "red",
              "value": 85
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_memory_used{node=\"murderbot\"} / nvidia_gpu_memory_total{node=\"murderbot\"} * 100"
        }
      ]
    },
    {
      "id": 3,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 14,
        "y": 0
      },
      "fieldConfig.defaults": {
        "unit": "percent",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_utilization{node=\"murderbot\"}",
          "legendFormat": "{{gpu}}"
        }
      ],
      "fieldConfig.defaults.thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "red",
            "value": null
          },
          {
            "color": "#EAB839",
            "value": 50
          },
          {
            "color": "green",
            "value": 75
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "GPU Temperature",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 20,
        "y": 0
      },
      "fieldConfig.defaults": {
        "unit": "celsius",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_temperature{node=\"murderbot\"}",
          "legendFormat": "{{gpu}}"
        }
      ],
      "fieldConfig.defaults.thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "#EAB839",
            "value": 70
          },
          {
            "color": "red",
            "value": 85
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Power Draw (W)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "fieldConfig.defaults": {
        "unit": "watt",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_power_usage{node=\"murderbot\"}",
          "legendFormat": "{{gpu}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "GPU Clock (MHz)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "fieldConfig.defaults": {
        "unit": "Hertz",
        "custom": {
          "fillOpacity": 10
        },
        "decimals": 0
      },
      "targets": [
        {
          "expr": "nvidia_gpu_clock_graphics{node=\"murderbot\"}",
          "legendFormat": "{{gpu}} current"
        }
      ]
    },
    {
      "id": 7,
      "title": "Fan Speed %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "fieldConfig.defaults": {
        "unit": "percent",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_fan_speed{node=\"murderbot\"}",
          "legendFormat": "{{gpu}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Predicted Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig.defaults": {
        "unit": "tokps",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "rate(llamacpp:tokens_predicted_total{node=\"murderbot\"}[5m])",
          "legendFormat": "{{gpu}}"
        }
      ],
      "fieldConfig.defaults.thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "green",
            "value": null
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "Prompt Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig.defaults": {
        "unit": "tokps",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "rate(llamacpp:prompt_tokens_total{node=\"murderbot\"}[5m])",
          "legendFormat": "{{gpu}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Total Tokens Processed",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig.defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 10
        }
      },
      "targets": [
        {
          "expr": "increase(llamacpp:tokens_predicted_total{node=\"murderbot\"}[5m])",
          "legendFormat": "predicted"
        },
        {
          "expr": "increase(llamacpp:prompt_tokens_total{node=\"murderbot\"}[5m])",
          "legendFormat": "prompt",
          "hide": false
        }
      ]
    },
    {
      "id": 11,
      "title": "Active Requests / Deferred",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig.defaults": {
        "custom": {
          "fillOpacity": 5
        }
      },
      "targets": [
        {
          "expr": "llamacpp:requests_processing{node=\"murderbot\"}",
          "legendFormat": "active"
        },
        {
          "expr": "llamacpp:requests_deferred{node=\"murderbot\"}",
          "legendFormat": "deferred",
          "hide": false
        }
      ]
    },
    {
      "id": 12,
      "title": "GPU Info",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig.defaults": {
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "blue",
              "value": null
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "nvidia_gpu_info{node=\"murderbot\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "gpu": "GPU ID",
              "instance": "Instance"
            },
            "indexByName": {},
            "excludeByName": [
              "Value"
            ]
          }
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": [],
  "version": 1,
  "lifetime": ""
}