{
  "title": "LLM Manager",
  "uid": "llm-manager-overview",
  "tags": [
    "llm-manager"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "llm_queue_depth",
          "legendFormat": "queued"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Jobs",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "blue",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "llm_queue_active_jobs",
          "legendFormat": "running"
        }
      ]
    },
    {
      "id": 3,
      "title": "Online Runners",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "llm_backend_active_runners",
          "legendFormat": "runners"
        }
      ]
    },
    {
      "id": 4,
      "title": "Fast-path req/min",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(llm_fastpath_requests_total{status=\"completed\"}[2m])) * 60",
          "legendFormat": "fast-path/min"
        }
      ]
    },
    {
      "id": 5,
      "title": "Job Completions",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "completed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "completed",
          "expr": "sum(rate(llm_scheduler_v2_jobs_completed_total{status=\"completed\"}[2m]))",
          "legendFormat": "completed"
        },
        {
          "refId": "failed",
          "expr": "sum(rate(llm_scheduler_v2_jobs_completed_total{status=\"failed\"}[2m]))",
          "legendFormat": "failed"
        },
        {
          "refId": "fastpath",
          "expr": "sum(rate(llm_fastpath_requests_total{status=\"completed\"}[2m]))",
          "legendFormat": "fast-path completed"
        }
      ]
    },
    {
      "id": 6,
      "title": "Fast-path vs Queue",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(llm_fastpath_requests_total[2m]))",
          "legendFormat": "fast-path (direct)"
        },
        {
          "expr": "sum(rate(llm_queue_jobs_submitted_total[2m]))",
          "legendFormat": "queued (swap needed)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Inference Duration",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_fastpath_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "fast-path p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_fastpath_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "fast-path p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_queue_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "queue p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_queue_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "queue p95"
        }
      ]
    },
    {
      "id": 8,
      "title": "Queue Wait Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_scheduler_v2_job_wait_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_scheduler_v2_job_wait_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_scheduler_v2_job_wait_by_app_seconds_bucket[5m])) by (le, app))",
          "legendFormat": "{{app}} p50"
        }
      ]
    },
    {
      "id": 9,
      "title": "VRAM Used % by Runner",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "llm_runner_vram_used_bytes / llm_runner_vram_total_bytes * 100",
          "legendFormat": "{{runner}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Token Throughput",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(llm_inference_completion_tokens_total[2m])) by (model)",
          "legendFormat": "{{model}} (out)"
        },
        {
          "expr": "sum(rate(llm_inference_prompt_tokens_total[2m])) by (model)",
          "legendFormat": "{{model}} (in)"
        }
      ]
    },
    {
      "id": 11,
      "title": "Model Swaps / hr",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(llm_scheduler_v2_model_swap_total[5m])) by (runner) * 3600",
          "legendFormat": "{{runner}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Swap Duration P95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_scheduler_v2_model_swap_seconds_bucket[5m])) by (le, runner))",
          "legendFormat": "{{runner}} p95"
        }
      ]
    },
    {
      "id": 13,
      "title": "Runner Idle State",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "BUSY",
                  "color": "red"
                },
                "1": {
                  "text": "IDLE",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "llm_runner_is_idle",
          "legendFormat": "{{runner}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Alias Config",
      "type": "table",
      "description": "Active aliases with base model and string metadata. Refreshed every 30s.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "options": {
        "sortBy": [
          {
            "displayName": "alias",
            "desc": false
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "__name__"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "llm_alias_info",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "alias": "Alias",
              "base_model": "Base Model",
              "has_system_prompt": "System Prompt"
            },
            "indexByName": {
              "alias": 0,
              "base_model": 1,
              "has_system_prompt": 2
            }
          }
        }
      ]
    },
    {
      "id": 15,
      "title": "Alias Parameters",
      "type": "table",
      "description": "Numeric parameters configured per alias. Refreshed every 30s.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "options": {
        "sortBy": [
          {
            "displayName": "alias",
            "desc": false
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          },
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Value"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "__name__"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "llm_alias_param",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "alias": "Alias",
              "param": "Parameter",
              "Value": "Value"
            },
            "indexByName": {
              "alias": 0,
              "param": 1,
              "Value": 2
            }
          }
        }
      ]
    },
    {
      "id": 16,
      "title": "Runner Model Parameter Overrides",
      "type": "table",
      "description": "Per-runner model param overrides (model_runner_params table). Refreshed every 30s.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 46
      },
      "options": {
        "sortBy": [
          {
            "displayName": "model",
            "desc": false
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          },
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "__name__"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "llm_runner_model_param",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "model": "Model",
              "runner": "Runner",
              "param": "Parameter",
              "Value": "Value"
            },
            "indexByName": {
              "model": 0,
              "runner": 1,
              "param": 2,
              "Value": 3
            }
          }
        }
      ]
    }
  ]
}