      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load1{job=\"mac-mini-node\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load5{job=\"mac-mini-node\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "node_load15{job=\"mac-mini-node\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ]
