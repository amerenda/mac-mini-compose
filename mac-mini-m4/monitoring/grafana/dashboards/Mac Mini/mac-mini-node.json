          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*write.*"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
