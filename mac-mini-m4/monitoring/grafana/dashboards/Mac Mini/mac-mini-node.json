    {
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 10
    },
    {
      "type": "timeseries",
      "title": "CPU Usage by Mode",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{job=\"mac-mini-node\", mode=\"user\"}[5m])) * 100",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{job=\"mac-mini-node\", mode=\"system\"}[5m])) * 100",
          "legendFormat": "system",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{job=\"mac-mini-node\", mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "iowait",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{job=\"mac-mini-node\", mode=\"idle\"}[5m])) * 100",
          "legendFormat": "idle",
          "refId": "D"
