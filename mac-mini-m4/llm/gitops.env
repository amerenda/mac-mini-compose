# Merged into llm/.env on every Komodo deploy (see llm/pre-deploy.sh).
# Edit via PR — nothing here is applied by hand on the Mac Mini.
#
# LAN IP of the Mac Mini (same host as Komodo, Postgres, etc. — see k3s ingresses / infra docs).
# k3s pods reach this via the home LAN / Tailscale-advertised 10.100.20.0/24 route.
AGENT_ADDRESS=https://10.100.20.18:8090

# Host paths for compose + llm-agent disk stats. Required as a last-wins override: Komodo
# may run pre-deploy in Linux (no /Users), which cannot infer these; duplicate keys in
# llm/.env are merged by Compose with the last definition winning.
OLLAMA_DATA_HOST_PATH=/Users/alex/.ollama
OLLAMA_MODELS_HOST_PATH=/Users/alex/.ollama/models

# Optional: override unified-memory pool (bytes) if Ansible has not written
# llm/.ansible-memory-bytes yet. sysctl hw.memsize on the Mac = correct value.
# AGENT_UNIFIED_VRAM_TOTAL_BYTES=25769803776

# Optional: pin agent image when you cannot wait for target-version resolution:
# AGENT_IMAGE_TAG=sha-abc1234
