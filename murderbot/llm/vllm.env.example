# vLLM container tunables for murderbot stack.
# pre-deploy copies this to llm/vllm.env when missing, then injects HF_TOKEN from BWS.
#
# To override VLLM_MODEL or VLLM_MODELS_HOST_PATH without editing this file,
# set them in llm/ollama.ui.env — pre-deploy will pick them up.

# HF_TOKEN is injected by pre-deploy.sh from BWS secret "hugging-face-read-only".
# HF_TOKEN=

# Model to load at startup (HuggingFace repo ID or local path under /mnt/hf-cache).
# Override in ollama.ui.env as VLLM_MODEL=org/model-id
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# GPU memory fraction vLLM may use (0.0–1.0). Default 0.9 = single-GPU, no sharing.
# VLLM_GPU_MEM_UTIL=0.9

# vLLM image tag. Defaults to latest in compose.yaml.
# VLLM_IMAGE_TAG=latest
